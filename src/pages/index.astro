---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="min-h-screen flex flex-col justify-center items-center text-center px-4 bg-blue-900 text-white">
		<h1 class="text-5xl font-bold mb-4">Nikos Papadakis</h1>
		<h2 class="text-2xl text-amber-500 mb-6">Junior Frontend Developer</h2>
		<p class="text-yellow-700 max-w-md text-lg">Building clean web apps with React and TypeScript. I enjoy turning complex problems into simple, elegant solutions.</p>
	</section>
	<section class="bg-blue-700 text-white py-20 px-4">
		<h2 class="text-3xl font-bold text-center mb-12">Projects</h2>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
			<div class="bg-blue-600 rounded-lg p-6">
				<h3 class="text-xl font-bold mb-2">Workout Tracker</h3>
				<p class="text-blue-200 mb-4">A full-stack app for tracking workouts, exercises, and sets. Built with React, Node.js/Express and MongoDB Atlas.</p>
				<a href="https://github.com/orfneos/workout-tracker" class="text-amber-600 hover:underline">GitHub →</a>
			</div>
			<div class="bg-blue-600 rounded-lg p-6">
				<h3 class="text-xl font-bold mb-2">Fullstack Todo App</h3>
				<p class="text-blue-200 mb-4">A fullstack Todo app where users can add, complete, and delete tasks. Data stored permanently in MongoDB.</p>
				<a href="https://github.com/orfneos/fullstack-todo-app" class="text-amber-600 hover:underline">GitHub →</a>
			</div>
			<div class="bg-blue-600 rounded-lg p-6">
				<h3 class="text-xl font-bold mb-2">Weather App</h3>
				<p class="text-blue-200 mb-4">Search current weather and 5-day forecast for any city. Built with React and TypeScript.</p>
				<a href="https://github.com/orfneos/weather-app" class="text-amber-600 hover:underline">GitHub →</a>
			</div>

			<div class="bg-blue-600 rounded-lg p-6">
				<h3 class="text-xl font-bold mb-2">Calculator App</h3>
				<p class="text-blue-200 mb-4">A fully functional calculator with chained operations and expression display. Built with React and TypeScript.</p>
				<a href="https://github.com/orfneos/calculator-app" class="text-amber-600 hover:underline">GitHub →</a>
			</div>
		</div>
	</section>
	<section class="bg-gray-950 text-white py-20 px-4 text-center">
		<h2 class="text-3xl font-bold mb-8">Contact</h2>
		<p class="text-gray-400 mb-8">Feel free to reach out — I'm open to opportunities.</p>
		<div class="flex justify-center gap-6">
			<a href="mailto:orfneos@yahoo.gr" class="text-blue-400 hover:underline">Email</a>
			<a href="https://github.com/orfneos" class="text-blue-400 hover:underline">GitHub</a>
		</div>
</section>
</Layout>


